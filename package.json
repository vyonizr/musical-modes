    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@serwist/next": "^9.5.11",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-joyride": "^3.1.0",
    "serwist": "^9.5.11",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@serwist/cli": "^9.5.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "prettier": "2.8.7",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
